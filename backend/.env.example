LLM_PROVIDER_ORDER=ollama,openrouter,openai
ANALYZE_WORKSPACE_ROOT=
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
EXPLAIN_MAX_CODE_CHARS=12000

# Preferred free path: local Ollama first (no API fee)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Optional fallback: OpenRouter free router
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free

# Optional fallback: OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
